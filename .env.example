APP_NAME=MugShot
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mugshot
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

## MugShot Application Settings

SENTRY_LARAVEL_DSN=

MUGSHOT_TIMEOUT=30
MUGSHOT_CACHE_TIME=90
MUGSHOT_HOMEPAGE_REDIRECT=

## MugShot Puppeteer Settings

MUGSHOT_BINARY_NODE=
MUGSHOT_BINARY_NPM=
MUGSHOT_NODE_MODULES_PATH=
MUGSHOT_BINARY_CHROME=/usr/bin/google-chrome-stable
MUGSHOT_PUPPETEER_PROXY=
MUGSHOT_PUPPETEER_SANDBOX=false
MUGSHOT_REMOTE_CHROME_HOST=
MUGSHOT_REMOTE_CHROME_PORT="9222"
